# ─── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Approach D (PaNSegNet / nnTransUNetTrainerV2) — fully isolated ───────────
approach_d/.venv/
approach_d/PaNSegNet/
approach_d/nnunet_v1/
approach_d/predictions/

# ─── Python bytecode ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ─── Medical imaging data (obtain via data access; not distributed) ───────────
data/images/
data/masks/
data/masks_fixed/

# ─── NIfTI files everywhere (catch-all for any accidentally added scans) ──────
*.nii
*.nii.gz

# ─── nnU-Net runtime directories (nnUnet/ is the actual folder name) ──────────
nnUnet/nnUNet_preprocessed/
nnUnet/nnUNet_results/
nnUnet/nnUNet_raw/Dataset*/imagesTr/
nnUnet/nnUNet_raw/Dataset*/labelsTr/
nnUnet/nnUNet_raw/Dataset*/imagesTs/
nnUnet/plan_and_preprocess.log
nnUnet/train_*.log

# ─── Model checkpoints ────────────────────────────────────────────────────────
**/*.pth
**/*.pt
**/*.ckpt
**/*.pkl
**/*.npz

